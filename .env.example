# ════════════════════════════════════════════
#  .env  —  Copia este archivo como ".env"
#  y rellena solo las APIs que tengas
# ════════════════════════════════════════════

# ── GUIÓN: LLM (elige uno o varios, el pipeline prueba en orden) ─────────────

# OpenAI (primera opción)
OPENAI_API_KEY=

# DeepSeek (segunda opción, mucho más barato que OpenAI)
# Obtén tu key en: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Ollama local (tercera opción, gratis, requiere Ollama corriendo)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── VOZ ──────────────────────────────────────────────────────────────────────

# ElevenLabs (primera opción, mejor calidad)
# Obtén tu key en: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=
# Voice ID del narrador: ve a Voices → click en la voz → copia el ID
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Si no hay API de ElevenLabs, el pipeline usa pyttsx3 (voz del sistema, gratis)

# ── VIDEO: VEO 3 (Vertex AI) ─────────────────────────────────────────────────

# Si estas variables están vacías, el pipeline genera pantalla negra narrada
# Instrucciones de setup en el README

GOOGLE_APPLICATION_CREDENTIALS=./gcloud-key.json
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GCS_BUCKET=
